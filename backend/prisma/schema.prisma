generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Demo_Telecom {
  id Int @id @default(autoincrement())
  dni String @unique @db.VarChar(18)
  num_telefono String @unique @db.VarChar(9)
  num_contacto String @db.VarChar(9)
  nombre_completo String @db.VarChar(255)
  verificado Boolean @default(false)
  direccion_ip String? @db.VarChar(255)
  fecha_consentimiento DateTime @default(now())
}

model Energia_Global_Spain {
  id Int @id @default(autoincrement())
  dni String @unique @db.VarChar(18)
  num_telefono String @unique @db.VarChar(9)
  num_contacto String @db.VarChar(9)
  nombre_completo String @db.VarChar(255)
  verificado Boolean @default(false)
  direccion_ip String? @db.VarChar(255)
  fecha_consentimiento DateTime @default(now())
}


